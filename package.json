{
  "name": "overseer",
  "version": "1.0.0",
  "description": "Self-hosted AI Agent with full VPS access - Telegram, Discord, and Web Admin. Cross-platform: Windows, Linux, macOS.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --test --import tsx",
    "bot": "cross-env NODE_ENV=production tsx src/bot/index.ts",
    "bot:dev": "tsx watch src/bot/index.ts",
    "discord": "cross-env NODE_ENV=production tsx src/bot/discord.ts",
    "discord:dev": "tsx watch src/bot/discord.ts",
    "slack": "cross-env NODE_ENV=production tsx src/bot/slack.ts",
    "slack:dev": "tsx watch src/bot/slack.ts",
    "whatsapp": "cross-env NODE_ENV=production tsx src/bot/whatsapp.ts",
    "whatsapp:dev": "tsx watch src/bot/whatsapp.ts",
    "matrix": "cross-env NODE_ENV=production tsx src/bot/matrix.ts",
    "matrix:dev": "tsx watch src/bot/matrix.ts",
    "bots": "concurrently \"npm run bot\" \"npm run discord\"",
    "bots:dev": "concurrently \"npm run bot:dev\" \"npm run discord:dev\"",
    "agent": "cross-env NODE_ENV=production tsx src/agent/runner.ts",
    "agent:dev": "tsx watch src/agent/runner.ts",
    "cli": "tsx src/cli/index.ts",
    "cron:list": "tsx src/cli/index.ts cron list",
    "cron:history": "tsx src/cli/index.ts cron history",
    "db:init": "tsx src/database/init.ts",
    "setup": "npm run db:init",
    "lint": "node -e \"console.log('Lint is not configured (Next.js 16 CLI removed next lint). Run pnpm typecheck instead.')\"",
    "typecheck": "tsc --noEmit",
    "clean": "shx rm -rf .next node_modules/.cache",
    "clean:data": "shx rm -rf data/*.db data/*.db-wal data/*.db-shm",
    "postinstall": "node scripts/postinstall.js",
    "skills:build": "node scripts/build-skills.mjs"
  },
  "bin": {
    "overseer": "./src/cli/index.ts"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.60",
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/azure": "^3.0.30",
    "@ai-sdk/cohere": "^3.0.21",
    "@ai-sdk/deepinfra": "^2.0.34",
    "@ai-sdk/deepseek": "^2.0.20",
    "@ai-sdk/fireworks": "^2.0.34",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/groq": "^3.0.24",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.29",
    "@ai-sdk/perplexity": "^3.0.19",
    "@ai-sdk/react": "^3.0.88",
    "@ai-sdk/togetherai": "^2.0.33",
    "@ai-sdk/xai": "^3.0.57",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@slack/bolt": "^4.6.0",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/next": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ai": "^6.0.79",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "cron-parser": "^5.5.0",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "lucide-react": "^0.564.0",
    "mammoth": "^1.10.0",
    "matrix-js-sdk": "40.2.0",
    "next": "^16.1.6",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.1",
    "telegraf": "^4.16.3",
    "use-stick-to-bottom": "^1.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "undici": "6.23.0",
      "fast-xml-parser": "5.3.4",
      "qs": "6.14.2"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "esbuild": "^0.25.9",
    "shx": "^0.3.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
